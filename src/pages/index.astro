---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ToolCard from '../components/ToolCard.astro';
import Footer from '../components/Footer.astro';

const featuredTools = [
  {
    title: "Universal Engagement Calculator",
    description: "Instantly calculate your engagement rates across X, Instagram, and TikTok to optimize your content hooks.",
    icon: "📈",
    tag: "CREATOR",
    href: "/engagement-rate-calculator"
  },
  {
    title: "Instagram Reels Overlay Tester",
    description: "Upload your media to visually check if native app captions or UI icons block your text safe zones.",
    icon: "📱",
    tag: "VIDEO",
    href: "/instagram-reels-overlay-tester"
  },
  {
    title: "ROAS & Profitability Engine",
    description: "Calculate exact Return on Ad Spend, break-even points, and net profits for Meta and Google campaigns.",
    icon: "💰",
    tag: "MARKETING",
    href: "/roas-calculator"
  },
  {
    title: "LinkedIn Preview Formatter",
    description: "Style your LinkedIn posts with bold and italic text while previewing exactly where the 'see more' cutoff will land.",
    icon: "✍️",
    tag: "SOCIAL",
    href: "/linkedin-preview-formatter"
  }
];
---

<Layout>
	<main class="min-h-screen">
		<Nav />
		<Hero />
		
		<section id="tools" class="max-w-7xl mx-auto px-6 py-12 sm:py-20">
			<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
				<div class="max-w-xl">
					<h2 class="text-display-lg text-ink mb-4">Essential tools for modern creators.</h2>
					<p class="text-body text-sm sm:text-base">Stop guessing your numbers. Access professional-grade utilities in a single, beautiful interface designed for high-growth creators and marketers.</p>
				</div>
				<a href="#" class="text-primary font-medium hover:underline flex items-center gap-1 shrink-0">
					View all tools
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
					</svg>
				</a>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{featuredTools.map(tool => (
					<ToolCard {...tool} />
				))}
			</div>
		</section>

		<section class="bg-surface-card border-y border-hairline py-16 sm:py-24 text-center px-6">
			<div class="max-w-3xl mx-auto">
				<h2 class="text-display-lg text-ink mb-6">Built for scale.</h2>
				<p class="text-body text-base sm:text-lg mb-10">
					Every tool is optimized for the daily workflow of digital entrepreneurs. 
					Privacy-first, fast, and always free for individual creators.
				</p>
				<div class="flex justify-center gap-4">
					<a href="#" class="bg-primary text-white px-8 py-3 rounded-md font-medium hover:bg-primary-active transition-all shadow-md active:scale-95">
						Join our Community
					</a>
				</div>
			</div>
		</section>


		<Footer />
	</main>
</Layout>
