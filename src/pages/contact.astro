---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | Get Micro Tools">
  <Nav />
  <main class="max-w-4xl mx-auto px-6 py-24 text-center">
    <header class="mb-16">
      <h1 class="text-display-md text-ink mb-4">Contact Us</h1>
      <p class="text-body-md text-muted max-w-2xl mx-auto">
        Have questions, feedback, or a tool suggestion? We'd love to hear from you. 
        Our team typically responds within 24-48 hours.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
      <div class="bg-surface-card border border-hairline rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-ink font-semibold mb-2">Email</h3>
        <p class="text-body-sm text-muted mb-4">General inquiries and support</p>
        <a href="mailto:hello@getmicrotools.com" class="text-primary font-medium hover:underline">hello@getmicrotools.com</a>
      </div>

      <div class="bg-surface-card border border-hairline rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
          </svg>
        </div>
        <h3 class="text-ink font-semibold mb-2">Twitter / X</h3>
        <p class="text-body-sm text-muted mb-4">For quick updates and feedback</p>
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-primary font-medium hover:underline">@GetMicroTools</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
