---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import UploadZone from '../components/instagram-preview/UploadZone.astro';
import SafeZoneGuide from '../components/instagram-preview/SafeZoneGuide.astro';
import ReelsMockup from '../components/instagram-preview/ReelsMockup.astro';

const title = "Instagram Reels Safe Zone Checker | Reels Overlay Tester";
const description = "Test your content with our free Instagram reels safe zone checker. Ensure your text and visuals aren't blocked by UI elements with our reels overlay tester.";
const keywords = "Instagram reels safe zone checker, reels overlay tester, instagram reel safe zone checker, overlay tester, overlay safe zone";
const url = "https://getmicro.tools/instagram-reels-overlay-tester";
---

<Layout title={title} description={description} keywords={keywords} url={url}>
  {/* Force dark mode for this page specifically by wrapping the content */}
  <div class="dark bg-canvas min-h-screen w-full flex flex-col">
    <Nav />

    <main class="flex-grow text-ink font-sans">
      <div class="max-w-7xl mx-auto px-6 py-12 md:py-24">
      {/* Header */}
      <header class="mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-pill bg-surface-strong text-ink text-[11px] font-semibold uppercase tracking-wider mb-6">
          Visual Testing
        </div>
        <h1 class="text-display-lg md:text-display-mega mb-6 tracking-tight text-ink">Reels Overlay Tester</h1>
        <p class="text-body text-lg max-w-2xl leading-relaxed">
          Upload your media to see exactly how it will look inside the Instagram Reels player. 
          Identify "Dead Zones" where the UI covers your hooks and captions.
        </p>
      </header>

      {/* Main Layout Grid */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        {/* Left Side: Upload Zone */}
        <div class="space-y-8">
          <UploadZone />
          <SafeZoneGuide />
        </div>

        {/* Right Side: Smartphone Mockup */}
        <ReelsMockup />
      </div>

      {/* SEO Content Section */}
      <section class="mt-24 pt-24 border-t border-hairline">
        <div class="max-w-4xl">
          <h2 class="text-display-lg mb-8 text-ink">Instagram Reels Safe Zone Checker: The Ultimate Guide to Perfect Content</h2>
          <div class="prose prose-ink prose-lg max-w-none space-y-8 text-body leading-relaxed">
            <p>
              When you're creating content for Instagram Reels, you're not just fighting the algorithm—you're fighting the UI. Every Reel you post is covered by a layer of buttons, text, and icons that can obscure your message. That's why using an <strong>Instagram reels safe zone checker</strong> is essential for any serious creator.
            </p>

            <h3 class="text-display-md text-ink mt-12 mb-6">What is an Instagram Reels Safe Zone?</h3>
            <p>
              The "safe zone" refers to the area of your 9:16 vertical video that is guaranteed to be visible to all users, regardless of their device or the specific version of the Instagram app they are using. Instagram overlays several UI elements on top of your video:
            </p>
            <ul class="list-disc pl-6 space-y-2">
              <li><strong>Bottom Overlay:</strong> The username, caption, and audio track information.</li>
              <li><strong>Right Action Bar:</strong> Like, comment, share, and three-dot menu icons.</li>
              <li><strong>Top Bar:</strong> The "Reels" heading and camera/search icons.</li>
            </ul>
            <p>
              If your key text or visual "hooks" fall into these areas, they become unreadable. An <strong>instagram reel safe zone checker</strong> helps you visualize these "dead zones" before you hit publish.
            </p>

            <h3 class="text-display-md text-ink mt-12 mb-6">Why You Need a Reels Overlay Tester</h3>
            <p>
              Precision is key in social media marketing. If a viewer can't read your caption because it's buried under a "Follow" button, they're likely to keep scrolling. A <strong>reels overlay tester</strong> allows you to upload your video or image and see exactly where the Instagram interface will sit.
            </p>

            <h4 class="text-title-md text-ink mt-8 mb-4">1. Protect Your Hooks</h4>
            <p>
              The first three seconds of a Reel are the most important. Often, creators place their main hook (text) at the very top or bottom of the screen. Without an <strong>overlay tester</strong>, you might accidentally place your headline right under the top "Reels" text or the bottom caption.
            </p>

            <h4 class="text-title-md text-ink mt-8 mb-4">2. Optimize for All Devices</h4>
            <p>
              Instagram's UI scales differently on various screen aspect ratios. While it might look fine on your iPhone 15, it could be cut off on a Google Pixel or a Samsung Galaxy. A robust <strong>overlay safe zone</strong> guide ensures your content is responsive.
            </p>

            <h4 class="text-title-md text-ink mt-8 mb-4">3. Professionalism</h4>
            <p>
              High-quality content isn't just about resolution; it's about composition. Using a <strong>reels overlay tester</strong> shows that you care about the user experience, leading to higher engagement and better brand perception.
            </p>

            <h3 class="text-display-md text-ink mt-12 mb-6">How to Use Our Instagram Reel Safe Zone Checker</h3>
            <p>
              Our tool is designed to be the simplest <strong>instagram reels safe zone checker</strong> on the web. Here’s how to get the most out of it:
            </p>
            <ol class="list-decimal pl-6 space-y-4">
              <li><strong>Upload Your Media:</strong> Drag and drop your video (MP4) or image (JPG/PNG) into the tester.</li>
              <li><strong>Review the Overlays:</strong> Look at the right-hand preview. You'll see a real-time mockup of the Instagram Reels interface.</li>
              <li><strong>Identify Blocked Areas:</strong> Check if your text, face, or product is being covered by the interaction icons or the caption area.</li>
              <li><strong>Adjust and Re-test:</strong> If your content is blocked, move your elements toward the center and re-upload to confirm they are in the <strong>overlay safe zone</strong>.</li>
            </ol>

            <h3 class="text-display-md text-ink mt-12 mb-6">Common Pitfalls in Reels Design</h3>
            <p>
              Many creators make the mistake of designing their Reels in a "vacuum"—forgetting that the final product will have a layer of UI on top. 
            </p>
            <ul class="list-disc pl-6 space-y-2">
              <li><strong>The "Dead Zone" at the Bottom:</strong> The bottom 25% of a Reel is heavily crowded. Avoid placing any text here.</li>
              <li><strong>The "Right Edge" Trap:</strong> The engagement icons sit on the right. If you frame your subject too far to the right, their face might be covered by the "Like" heart.</li>
              <li><strong>Ignoring the Top Notch:</strong> Different phones have different "notches" or "punch-hole" cameras. Our <strong>overlay tester</strong> accounts for the general top-bar area to keep your headers safe.</li>
            </ul>

            <h3 class="text-display-md text-ink mt-12 mb-6">Best Practices for Reels Dimensions and Aspect Ratio</h3>
            <p>
              To ensure your content looks its best in the <strong>instagram reel safe zone checker</strong>, you must start with the correct dimensions. Instagram Reels are designed for a 9:16 aspect ratio. The ideal resolution is 1080 x 1920 pixels. 
            </p>
            <p>
              If you upload a video with a different aspect ratio, Instagram will either crop it or add borders, which can completely throw off your <strong>overlay safe zone</strong> calculations. For example, a 4:5 video will have significant black bars at the top and bottom, which might make you think you have more space than you actually do once the UI is applied. 
            </p>
            <p>
              Always record or export your content in 1080x1920 to maintain consistency with our <strong>reels overlay tester</strong>. This ensures that the simulated UI elements align perfectly with how they will appear on a real device.
            </p>

            <h3 class="text-display-md text-ink mt-12 mb-6">Maximize Engagement with Overlay Safe Zone Awareness</h3>
            <p>
              Social media success is a game of inches. By ensuring every word of your caption and every visual detail of your video is visible, you remove friction for your audience. Using an <strong>instagram reels safe zone checker</strong> is a small step in your workflow that can lead to a massive difference in your reach and engagement rate.
            </p>
            <h3 class="text-display-md text-ink mt-12 mb-6">The Future of Reels Marketing and Creative Content</h3>
            <p>
              As Instagram continues to evolve, the interface will likely change, but the core principle remains: your content must be seen to be effective. Staying ahead of UI updates by regularly checking your designs in a <strong>reels overlay tester</strong> ensures that your brand remains at the forefront of digital storytelling. By mastering the <strong>overlay safe zone</strong>, you're not just making a video; you're crafting an experience that respects the viewer's attention and maximizes your potential for viral growth. 
            </p>
            <p>
              In the fast-paced world of social media, small optimizations lead to significant results. Whether you're an influencer, a small business owner, or a social media manager, the <strong>instagram reel safe zone checker</strong> is a vital tool in your creative arsenal. Don't let your hard work go to waste by having it covered up—test every Reel and ensure your message is clear every time.
            </p>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />

  <script>
    import { isVideoFile, getMediaConfig, getAspectRatioLabel } from '../utils/instagram-preview/media-helpers.js';

    const fileUpload = document.getElementById('file-upload');
    const mediaViewport = document.getElementById('media-viewport');
    const dropZone = document.getElementById('drop-zone');
    const toggleFitOriginal = document.getElementById('toggle-fit-original');
    const toggleFitFill = document.getElementById('toggle-fit-fill');
    const aspectBadge = document.getElementById('detected-aspect-ratio');

    let currentFitMode = 'original'; // 'original' by default

    const updateFitMode = (mode) => {
      currentFitMode = mode;
      
      // Update toggle buttons styling
      if (toggleFitOriginal && toggleFitFill) {
        if (mode === 'original') {
          toggleFitOriginal.className = "py-2 px-1 text-center rounded-lg transition-all duration-150 cursor-pointer bg-canvas-soft text-ink shadow-xs border border-hairline/10";
          toggleFitFill.className = "py-2 px-1 text-center rounded-lg transition-all duration-150 cursor-pointer text-muted hover:text-ink bg-transparent";
        } else {
          toggleFitOriginal.className = "py-2 px-1 text-center rounded-lg transition-all duration-150 cursor-pointer text-muted hover:text-ink bg-transparent";
          toggleFitFill.className = "py-2 px-1 text-center rounded-lg transition-all duration-150 cursor-pointer bg-canvas-soft text-ink shadow-xs border border-hairline/10";
        }
      }

      // Update active media if loaded
      if (mediaViewport) {
        const mediaElement = mediaViewport.querySelector('img, video');
        if (mediaElement) {
          if (mode === 'original') {
            mediaElement.classList.remove('object-cover');
            mediaElement.classList.add('object-contain');
          } else {
            mediaElement.classList.remove('object-contain');
            mediaElement.classList.add('object-cover');
          }
        }
      }
    };

    if (toggleFitOriginal && toggleFitFill) {
      toggleFitOriginal.addEventListener('click', () => updateFitMode('original'));
      toggleFitFill.addEventListener('click', () => updateFitMode('fill'));
    }

    const handleMedia = (file) => {
      if (!file) return;

      const reader = new FileReader();
      const isVideo = isVideoFile(file);

      reader.onload = (e) => {
        const source = e.target.result;
        mediaViewport.innerHTML = ''; // Clear preview

        const config = getMediaConfig(isVideo, currentFitMode);
        const element = document.createElement(config.tagName);
        element.className = config.className;
        
        // Set other attributes
        Object.entries(config.attributes).forEach(([key, value]) => {
          element[key] = value;
        });

        // Set aspect ratio detection
        if (isVideo) {
          element.addEventListener('loadedmetadata', () => {
            const width = element.videoWidth;
            const height = element.videoHeight;
            const label = getAspectRatioLabel(width, height);
            if (aspectBadge) {
              aspectBadge.textContent = label;
              aspectBadge.classList.remove('hidden');
            }
          });
        } else {
          element.addEventListener('load', () => {
            const width = element.naturalWidth;
            const height = element.naturalHeight;
            const label = getAspectRatioLabel(width, height);
            if (aspectBadge) {
              aspectBadge.textContent = label;
              aspectBadge.classList.remove('hidden');
            }
          });
        }

        element.src = source;
        mediaViewport.appendChild(element);
      };

      reader.readAsDataURL(file);
    };

    if (fileUpload && mediaViewport && dropZone) {
      fileUpload.addEventListener('change', (e) => {
        handleMedia(e.target.files[0]);
      });

      // Drag and Drop Logic
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
        }, false);
      });

      ['dragenter', 'dragover'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => {
          dropZone.classList.add('border-primary', 'bg-canvas-soft');
        }, false);
      });

      ['dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => {
          dropZone.classList.remove('border-primary', 'bg-canvas-soft');
        }, false);
      });

      dropZone.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const file = dt.files[0];
        handleMedia(file);
      }, false);
    }
  </script>
  </div>
</Layout>


