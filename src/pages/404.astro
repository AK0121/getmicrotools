---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
	title="Page Not Found | Get Micro Tools"
	description="The page you are looking for doesn't exist or has been moved."
>
	<main class="min-h-screen flex flex-col">
		<Nav />
		
		<section class="flex-grow flex items-center justify-center px-6 py-20">
			<div class="max-w-xl text-center">
				<span class="inline-block px-3 py-1 rounded-pill bg-primary/10 text-primary text-xs font-bold tracking-wider uppercase mb-6">
					Error 404
				</span>
				<h1 class="text-display-mega text-ink mb-6">Lost in the safe zones?</h1>
				<p class="text-body text-lg mb-10 max-w-md mx-auto">
					The page you're looking for doesn't exist. It might have been moved or the URL was mistyped.
				</p>
				
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a 
						href="/" 
						class="w-full sm:w-auto bg-primary hover:bg-primary-active text-white px-8 py-3 rounded-md font-medium transition-all active:scale-95 shadow-lg shadow-primary/20"
					>
						Back to Home
					</a>
					<a 
						href="/#tools" 
						class="w-full sm:w-auto bg-surface-card hover:bg-surface-strong text-ink border border-hairline px-8 py-3 rounded-md font-medium transition-all active:scale-95"
					>
						Browse Tools
					</a>
				</div>
			</div>
		</section>

		<Footer />
	</main>
</Layout>
