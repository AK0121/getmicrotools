---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Page Metadata
const title = "Engagement Rate Calculator - Free Social Media Tool | Get Micro Tools";
const description = "Calculate your engagement rate across Instagram, TikTok, Facebook, and YouTube with our free tool. Get professional-grade metrics for your social media growth.";
const keywords = "Engagement Rate Calculator, instagram engagement rate calculator, tiktok engagement rate calculator, facebook engagement rate calculator, free engagement rate calculator, social media engagement rate calculator, youtube engagement rate calculator";
const url = "https://getmicro.tools/engagement-rate-calculator";
---

<Layout 
  title={title} 
  description={description} 
  keywords={keywords}
  url={url}
>
  <Nav />

  <main class="min-h-screen bg-canvas">
    {/* Hero Header */}
    <header class="max-w-7xl mx-auto px-6 pt-24 pb-16 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-pill bg-surface-strong text-ink text-[11px] font-semibold uppercase tracking-wider mb-6">
        Creator Tools
      </div>
      <h1 class="text-display-lg md:text-display-mega text-ink mb-6">
        Engagement Rate Calculator
      </h1>
      <p class="text-body text-lg max-w-2xl mx-auto">
        Move beyond vanity metrics. Calculate your true impact across platforms using industry-standard formulas for organic and paid reach.
      </p>
    </header>

    {/* Calculator Section */}
    <section class="max-w-4xl mx-auto px-6 pb-24">
      <div class="bg-surface-card rounded-lg border border-hairline overflow-hidden shadow-sm">
        {/* Tabs - Scrollable on mobile */}
        <div class="flex overflow-x-auto no-scrollbar border-b border-hairline bg-canvas-soft">
          <button 
            class="flex-none px-6 py-4 text-sm font-medium transition-colors border-b-2 border-primary text-ink bg-surface-card"
            data-tab="instagram"
          >
            Instagram
          </button>
          <button 
            class="flex-none px-6 py-4 text-sm font-medium transition-colors border-b-2 border-transparent text-muted hover:text-ink"
            data-tab="tiktok"
          >
            TikTok
          </button>
          <button 
            class="flex-none px-6 py-4 text-sm font-medium transition-colors border-b-2 border-transparent text-muted hover:text-ink"
            data-tab="facebook"
          >
            Facebook
          </button>
          <button 
            class="flex-none px-6 py-4 text-sm font-medium transition-colors border-b-2 border-transparent text-muted hover:text-ink"
            data-tab="youtube"
          >
            YouTube
          </button>
          <button 
            class="flex-none px-6 py-4 text-sm font-medium transition-colors border-b-2 border-transparent text-muted hover:text-ink"
            data-tab="x"
          >
            X (Twitter)
          </button>
        </div>

        <div class="p-8 md:p-12">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            {/* Inputs Area */}
            <div id="inputs-container" class="space-y-6">
              {/* Instagram Inputs */}
              <div id="panel-instagram" class="space-y-6">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="ig-likes">Likes</label>
                    <input type="number" id="ig-likes" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="ig-comments">Comments</label>
                    <input type="number" id="ig-comments" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="ig-shares">Shares</label>
                    <input type="number" id="ig-shares" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="ig-saves">Saves</label>
                    <input type="number" id="ig-saves" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
                <div class="pt-4 border-t border-hairline-soft">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="ig-reach">Total Reach / Followers</label>
                    <input type="number" id="ig-reach" placeholder="0" class="w-full bg-canvas border border-hairline rounded-md px-4 py-3 text-ink font-medium focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
              </div>

              {/* TikTok Inputs */}
              <div id="panel-tiktok" class="space-y-6 hidden">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="tt-likes">Likes</label>
                    <input type="number" id="tt-likes" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="tt-comments">Comments</label>
                    <input type="number" id="tt-comments" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="tt-shares">Shares</label>
                  <input type="number" id="tt-shares" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                </div>
                <div class="pt-4 border-t border-hairline-soft">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="tt-views">Total Views / Followers</label>
                    <input type="number" id="tt-views" placeholder="0" class="w-full bg-canvas border border-hairline rounded-md px-4 py-3 text-ink font-medium focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
              </div>

              {/* Facebook Inputs */}
              <div id="panel-facebook" class="space-y-6 hidden">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="fb-reactions">Reactions</label>
                    <input type="number" id="fb-reactions" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="fb-comments">Comments</label>
                    <input type="number" id="fb-comments" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="fb-shares">Shares</label>
                  <input type="number" id="fb-shares" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                </div>
                <div class="pt-4 border-t border-hairline-soft">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="fb-reach">Total Reach / Followers</label>
                    <input type="number" id="fb-reach" placeholder="0" class="w-full bg-canvas border border-hairline rounded-md px-4 py-3 text-ink font-medium focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
              </div>

              {/* YouTube Inputs */}
              <div id="panel-youtube" class="space-y-6 hidden">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="yt-likes">Likes</label>
                    <input type="number" id="yt-likes" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="yt-comments">Comments</label>
                    <input type="number" id="yt-comments" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="yt-shares">Shares</label>
                  <input type="number" id="yt-shares" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                </div>
                <div class="pt-4 border-t border-hairline-soft">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="yt-views">Total Views / Subscribers</label>
                    <input type="number" id="yt-views" placeholder="0" class="w-full bg-canvas border border-hairline rounded-md px-4 py-3 text-ink font-medium focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
              </div>

              {/* X / Twitter Inputs */}
              <div id="panel-x" class="space-y-6 hidden">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="x-likes">Likes</label>
                    <input type="number" id="x-likes" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="x-retweets">Reposts</label>
                    <input type="number" id="x-retweets" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="x-replies">Replies</label>
                    <input type="number" id="x-replies" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="x-quotes">Quotes</label>
                    <input type="number" id="x-quotes" placeholder="0" class="w-full bg-canvas-soft border border-hairline rounded-md px-4 py-2.5 text-ink focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
                <div class="pt-4 border-t border-hairline-soft">
                  <div class="space-y-2">
                    <label class="text-xs font-semibold text-ink uppercase tracking-wider" for="x-impressions">Total Impressions</label>
                    <input type="number" id="x-impressions" placeholder="0" class="w-full bg-canvas border border-hairline rounded-md px-4 py-3 text-ink font-medium focus:outline-none focus:border-primary transition-colors" />
                  </div>
                </div>
              </div>
            </div>

            {/* Results Area */}
            <div class="flex flex-col justify-center items-center p-8 bg-canvas-soft rounded-lg border border-hairline-soft">
              <span class="text-caption-uppercase text-muted mb-4">Engagement Rate</span>
              <div class="flex items-baseline gap-1">
                <span id="result-value" class="text-display-mega text-ink">0.00</span>
                <span class="text-display-md text-muted">%</span>
              </div>
              <div id="engagement-label" class="mt-6 px-4 py-1.5 rounded-pill bg-timeline-grep/20 text-timeline-done font-semibold text-xs uppercase tracking-widest border border-timeline-done/20">
                Awaiting Data
              </div>
              
              <div class="mt-12 w-full space-y-4">
                <div class="flex justify-between text-sm">
                  <span class="text-muted">Total Interactions</span>
                  <span id="total-interactions" class="text-ink font-medium">0</span>
                </div>
                <div class="w-full h-px bg-hairline"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* SEO Content Section */}
    <section class="max-w-4xl mx-auto px-6 py-20 border-t border-hairline">
      <div class="prose prose-sm md:prose-base prose-ink max-w-none">
        <h2 class="text-display-sm text-ink mb-6">Understanding the Engagement Rate Calculator</h2>
        <p class="text-body mb-6">
          In the modern digital landscape, follower counts are often considered "vanity metrics." They look good on a profile but don't necessarily reflect the actual impact of your content. This is where an <strong>Engagement Rate Calculator</strong> becomes an essential tool for creators, marketers, and brands. Whether you're looking for an <strong>instagram engagement rate calculator</strong>, a <strong>tiktok engagement rate calculator</strong>, or a <strong>facebook engagement rate calculator</strong>, understanding how your audience interacts with your posts is the key to sustainable growth.
        </p>
        <p class="text-body mb-6">
          Our <strong>free engagement rate calculator</strong> is designed to provide a comprehensive look at your social media performance across multiple platforms. By analyzing likes, comments, shares, and saves against your total reach or followers, you can gain actionable insights into what truly resonates with your community.
        </p>

        <h3 class="text-title-md text-ink mb-4">Why Use a Social Media Engagement Rate Calculator?</h3>
        <p class="text-body mb-6">
          Engagement rate is the ultimate measure of content quality. A high engagement rate indicates that your audience is not just passively scrolling past your posts but is actively participating in the conversation. Brands and sponsors prioritize this metric because it directly correlates with trust and influence. If you have 100,000 followers but only 100 likes, your influence is likely lower than someone with 10,000 followers and 1,000 likes.
        </p>
        <p class="text-body mb-6">
          Using a <strong>social media engagement rate calculator</strong> helps you benchmark performance, identify content trends, optimize posting times, and negotiate better deals with potential partners.
        </p>

        <h3 class="text-title-md text-ink mb-4">How to Calculate Engagement Rate</h3>
        <p class="text-body mb-6">
          The basic formula for engagement rate is typically <code>((Likes + Comments + Shares + Saves) / Total Followers or Reach) * 100</code>. However, different platforms may require different approaches. For example, a <strong>youtube engagement rate calculator</strong> might factor in watch time and subscriber growth alongside likes and comments. Similarly, a <strong>facebook engagement rate calculator</strong> would place high importance on shares, as they are a primary driver of virality on that platform.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-12">
          <div class="bg-surface-card p-6 rounded-lg border border-hairline">
            <h4 class="text-title-sm text-ink mb-2">Instagram & TikTok</h4>
            <p class="text-caption text-body">
              As platforms shift towards "saves" and "shares" as primary ranking signals, our <strong>instagram engagement rate calculator</strong> and <strong>tiktok engagement rate calculator</strong> allow you to input these specific metrics for a more accurate calculation.
            </p>
          </div>
          <div class="bg-surface-card p-6 rounded-lg border border-hairline">
            <h4 class="text-title-sm text-ink mb-2">Facebook & YouTube</h4>
            <p class="text-caption text-body">
              Beyond simple likes, comments on YouTube often lead to deeper community building. A <strong>youtube engagement rate calculator</strong> can help you track the health of your channel over time, while Facebook users should focus on the power of shares.
            </p>
          </div>
        </div>

        <h3 class="text-title-md text-ink mb-4">What is a "Good" Engagement Rate?</h3>
        <p class="text-body mb-6">
          While it varies by industry and platform size, generally:
        </p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-2">
            <span class="text-primary mt-1">●</span>
            <span><strong class="text-ink">Less than 1%:</strong> Low engagement. It might be time to rethink your content strategy.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary mt-1">●</span>
            <span><strong class="text-ink">1% to 3%:</strong> Average/Good engagement. This is standard for many established accounts.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary mt-1">●</span>
            <span><strong class="text-ink">3% to 6%:</strong> High engagement. Your audience is very active and loyal.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary mt-1">●</span>
            <span><strong class="text-ink">Above 6%:</strong> Very High engagement. This usually indicates viral content.</span>
          </li>
        </ul>

        <h3 class="text-title-md text-ink mb-4">Tips to Boost Your Engagement</h3>
        <p class="text-body mb-6">
          If your results from the <strong>engagement rate calculator</strong> aren't where you want them to be, try asking more questions to encourage comments, posting more consistently, and engaging back with your community by replying to their feedback. High-quality visuals are also essential to stop the scroll.
        </p>

        <h3 class="text-title-md text-ink mb-4">Frequently Asked Questions</h3>
        <div class="space-y-6 mb-8">
          <div>
            <h4 class="text-ink font-semibold mb-2">Is this a free engagement rate calculator?</h4>
            <p class="text-body">Yes, our tool is 100% free to use. You can calculate metrics for as many accounts as you like without any hidden costs or registration requirements.</p>
          </div>
          <div>
            <h4 class="text-ink font-semibold mb-2">Which platforms does this calculator support?</h4>
            <p class="text-body">While we have dedicated tabs for Instagram, TikTok, and X (Twitter), you can use the general formulas to calculate rates for Facebook, YouTube, and LinkedIn by inputting the relevant interaction data.</p>
          </div>
          <div>
            <h4 class="text-ink font-semibold mb-2">Should I calculate based on followers or reach?</h4>
            <p class="text-body">Calculating based on <strong>reach</strong> is often more accurate for individual post performance, as it shows how many people who actually saw the post engaged with it. Calculating based on <strong>followers</strong> is better for understanding your overall account health and community loyalty.</p>
          </div>
          <div>
            <h4 class="text-ink font-semibold mb-2">How often should I check my engagement rate?</h4>
            <p class="text-body">We recommend checking your engagement rate weekly to spot trends and monthly to evaluate your overall content strategy. Significant changes in engagement can often signal a shift in platform algorithms or audience preferences.</p>
          </div>
        </div>

        <p class="text-body">
          Our <strong>free engagement rate calculator</strong> is here to help you navigate the complex world of social media metrics. Start calculating today and take the first step towards a more engaged and impactful online presence.
        </p>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    // Tab State
    let activeTab = 'instagram';

    // Elements
    const tabs = document.querySelectorAll('[data-tab]');
    const panels = {
      instagram: document.getElementById('panel-instagram'),
      tiktok: document.getElementById('panel-tiktok'),
      facebook: document.getElementById('panel-facebook'),
      youtube: document.getElementById('panel-youtube'),
      x: document.getElementById('panel-x')
    };
    
    const resultValue = document.getElementById('result-value');
    const totalInteractionsDisplay = document.getElementById('total-interactions');
    const engagementLabel = document.getElementById('engagement-label');

    // All Input IDs by platform
    const platformInputs = {
      instagram: ['ig-likes', 'ig-comments', 'ig-shares', 'ig-saves', 'ig-reach'],
      tiktok: ['tt-likes', 'tt-comments', 'tt-shares', 'tt-views'],
      facebook: ['fb-reactions', 'fb-comments', 'fb-shares', 'fb-reach'],
      youtube: ['yt-likes', 'yt-comments', 'yt-shares', 'yt-views'],
      x: ['x-likes', 'x-retweets', 'x-replies', 'x-quotes', 'x-impressions']
    };

    // Tab Switching
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        activeTab = target;

        // Update Tab UI
        tabs.forEach(t => {
          t.classList.remove('border-primary', 'text-ink', 'bg-surface-card');
          t.classList.add('border-transparent', 'text-muted');
        });
        tab.classList.add('border-primary', 'text-ink', 'bg-surface-card');
        tab.classList.remove('border-transparent', 'text-muted');

        // Toggle Panels
        Object.keys(panels).forEach(key => {
          if (key === target) {
            panels[key].classList.remove('hidden');
          } else {
            panels[key].classList.add('hidden');
          }
        });

        calculate();
      });
    });

    // Real-time Calculation
    const calculate = () => {
      let totalInteractions = 0;
      let totalReach = 0;
      let er = 0;

      const getVal = (id) => parseFloat(document.getElementById(id).value) || 0;

      if (activeTab === 'instagram') {
        totalInteractions = getVal('ig-likes') + getVal('ig-comments') + getVal('ig-shares') + getVal('ig-saves');
        totalReach = getVal('ig-reach');
      } else if (activeTab === 'tiktok') {
        totalInteractions = getVal('tt-likes') + getVal('tt-comments') + getVal('tt-shares');
        totalReach = getVal('tt-views');
      } else if (activeTab === 'facebook') {
        totalInteractions = getVal('fb-reactions') + getVal('fb-comments') + getVal('fb-shares');
        totalReach = getVal('fb-reach');
      } else if (activeTab === 'youtube') {
        totalInteractions = getVal('yt-likes') + getVal('yt-comments') + getVal('yt-shares');
        totalReach = getVal('yt-views');
      } else if (activeTab === 'x') {
        totalInteractions = getVal('x-likes') + getVal('x-retweets') + getVal('x-replies') + getVal('x-quotes');
        totalReach = getVal('x-impressions');
      }

      if (totalReach > 0) {
        er = (totalInteractions / totalReach) * 100;
      }

      // Update UI
      resultValue.innerText = er.toFixed(2);
      totalInteractionsDisplay.innerText = totalInteractions.toLocaleString();

      // Update Label
      if (totalReach === 0) {
        engagementLabel.innerText = "Awaiting Data";
        engagementLabel.className = "mt-6 px-4 py-1.5 rounded-pill bg-surface-strong text-muted font-semibold text-xs uppercase tracking-widest border border-hairline";
      } else if (er < 1) {
        engagementLabel.innerText = "Low";
        engagementLabel.className = "mt-6 px-4 py-1.5 rounded-pill bg-red-100 text-red-600 font-semibold text-xs uppercase tracking-widest border border-red-200";
      } else if (er < 3) {
        engagementLabel.innerText = "Average";
        engagementLabel.className = "mt-6 px-4 py-1.5 rounded-pill bg-blue-100 text-blue-600 font-semibold text-xs uppercase tracking-widest border border-blue-200";
      } else if (er < 6) {
        engagementLabel.innerText = "Good";
        engagementLabel.className = "mt-6 px-4 py-1.5 rounded-pill bg-green-100 text-green-600 font-semibold text-xs uppercase tracking-widest border border-green-200";
      } else {
        engagementLabel.innerText = "Very High";
        engagementLabel.className = "mt-6 px-4 py-1.5 rounded-pill bg-timeline-done/10 text-timeline-done font-semibold text-xs uppercase tracking-widest border border-timeline-done/20";
      }
    };

    // Listen to all inputs
    Object.values(platformInputs).flat().forEach(id => {
      document.getElementById(id).addEventListener('input', calculate);
    });
  </script>
</Layout>

<style>
  /* Inter font substitution for CursorGothic */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

  /* Custom typography classes to match DESIGN.md exactly */
  .text-caption-uppercase {
    font-size: 11px;
