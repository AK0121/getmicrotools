---
// src/components/instagram-preview/ReelsMockup.astro
---
<div class="flex flex-col items-center lg:items-end gap-6 w-full">
  {/* Toggle and info header */}
  <div id="mockup-header-container" class="w-full max-w-[360px] flex flex-col gap-3 transition-all duration-200">
    <div class="flex items-center justify-between">
      <span class="text-[11px] font-semibold text-muted uppercase tracking-wider">Preview Mode</span>
      <span id="detected-aspect-ratio" class="text-[10px] sm:text-xs font-semibold text-primary hidden bg-primary/10 px-2.5 py-0.5 rounded-full border border-primary/20"></span>
    </div>
    
    <div id="fit-mode-selector-container" class="grid grid-cols-2 p-1 bg-surface-card border border-hairline rounded-xl text-[10px] sm:text-xs font-medium relative z-20 transition-all duration-150">
      <button 
        type="button"
        id="toggle-fit-original"
        class="py-2 px-1 text-center rounded-lg transition-all duration-150 cursor-pointer bg-canvas-soft text-ink shadow-xs border border-hairline/10"
      >
        Original Fit (Instagram Default)
      </button>
      <button 
        type="button"
        id="toggle-fit-fill"
        class="py-2 px-1 text-center rounded-lg transition-all duration-150 cursor-pointer text-muted hover:text-ink bg-transparent"
      >
        Fill Screen (Zoomed)
      </button>
    </div>
  </div>

  {/* Mockup Outer Container (taller aspect ratio of 9/19 for modern viewports) */}
  <div id="mockup-container" class="relative w-full max-w-[360px] aspect-[9/19] bg-black rounded-2xl border border-hairline shadow-2xl overflow-hidden select-none show-bottom-nav transition-all duration-200">
    
    {/* Dynamic Media Container */}
    <div id="media-viewport" class="absolute inset-0 flex items-center justify-center bg-zinc-950">
      <div class="text-zinc-600 flex flex-col items-center gap-4 text-center px-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 opacity-40 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <p class="text-[10px] font-semibold uppercase tracking-[0.25em] opacity-40 text-white">Preview Area</p>
      </div>
    </div>

    {/* Shadows & Gradients overlays for UI readability */}
    {/* Top Gradient */}
    <div class="reels-overlay absolute top-0 left-0 right-0 h-28 bg-gradient-to-b from-black/45 via-black/10 to-transparent pointer-events-none z-10"></div>
    {/* Bottom Gradient */}
    <div class="reels-overlay absolute bottom-0 left-0 right-0 h-[45%] bg-gradient-to-t from-black/85 via-black/40 to-transparent pointer-events-none z-10"></div>

    {/* Top Navigation Overlay */}
    <div id="overlay-top-header" class="reels-overlay absolute top-3 left-0 right-0 h-12 flex items-center justify-between px-4 text-white z-30 select-none">
      <button class="pointer-events-auto p-1.5 hover:bg-white/10 rounded-full active:scale-95 transition-all duration-150">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
      </button>
      <div class="flex items-center gap-4 cursor-pointer pointer-events-auto active:opacity-80 transition-opacity">
        <div class="flex items-center gap-1">
          <span class="text-[15px] font-bold text-white tracking-tight">Reels</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" class="mt-0.5 opacity-90 text-white">
            <path d="M12 16.5l-6-6h12z"/>
          </svg>
        </div>
        <div class="flex items-center gap-1.5 opacity-70 hover:opacity-100 transition-opacity">
          <span class="text-[15px] font-semibold text-white tracking-tight">Friends</span>
          <span class="inline-flex w-7 h-4 bg-white/20 rounded-full p-[2px] items-center relative shrink-0">
            <span class="absolute left-[3px] w-2.5 h-2.5 rounded-full bg-white/40"></span>
            <span class="absolute right-[3px] w-2.5 h-2.5 rounded-full bg-white"></span>
          </span>
        </div>
      </div>
      <div class="w-8"></div>
    </div>

    {/* Bottom Left Info Area Wrapper */}
    <div id="bottom-info-area" class="reels-overlay absolute left-4 bottom-6 right-18 z-30 flex flex-col gap-2.5 pointer-events-none select-none text-white bottom-overlay-area">
      {/* Profile Section Overlay */}
      <div id="overlay-profile" class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-full border border-white/20 overflow-hidden bg-zinc-800 flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-400">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </div>
        <div class="flex items-center gap-2 pointer-events-auto">
          <span class="text-[13px] font-semibold tracking-wide text-white drop-shadow-sm truncate max-w-[120px]">Tyler_Durden</span>
          {/* IG Blue Verification Checkmark Starburst */}
          <svg class="w-[14px] h-[14px] text-[#0095f6] shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2a1 1 0 0 1 .7.3l.8.8a1 1 0 0 0 .7.3h1.1a1 1 0 0 1 1 1v1.1c0 .3.1.5.3.7l.8.8a1 1 0 0 1 0 1.4l-.8.8a1 1 0 0 0-.3.7v1.1a1 1 0 0 1-1 1h-1.1a1 1 0 0 0-.7.3l-.8.8a1 1 0 0 1-1.4 0l-.8-.8a1 1 0 0 0-.7.3H9.4a1 1 0 0 1-1-1v-1.1c0-.3-.1-.5-.3-.7l-.8-.8a1 1 0 0 1 0-1.4l.8-.8c.2-.2.3-.4.3-.7V6.4a1 1 0 0 1 1-1h1.1c.3 0 .5-.1.7-.3l.8-.8A1 1 0 0 1 12 2zm-1.8 13.7l5.2-5.2-1.4-1.4-3.8 3.8-1.8-1.8-1.4 1.4z"/>
          </svg>
          <button class="px-2.5 py-1 text-[11px] font-semibold border border-white/40 rounded-[6px] bg-transparent hover:bg-white/10 active:scale-95 transition-all duration-150 leading-none">
            Follow
          </button>
        </div>
      </div>

      {/* Caption Overlay */}
      <div id="overlay-caption" class="pointer-events-auto">
        <p class="text-[13px] text-white/95 leading-[1.4] drop-shadow-sm font-normal pr-4 line-clamp-2">
          Filmed in Compton '96. I still miss these guys! ...
        </p>
      </div>
    </div>

    {/* Right-Side Interaction Column Overlay (made more compact and smaller for realism) */}
    <div id="overlay-right-action" class="reels-overlay absolute right-2.5 bottom-6 flex flex-col items-center gap-2.5 z-30 select-none bottom-overlay-area">
      
      {/* Like Button */}
      <div class="flex flex-col items-center gap-0.5 group pointer-events-auto cursor-pointer">
        <button class="p-1 rounded-full hover:bg-white/10 active:scale-90 transition-all duration-150 text-white drop-shadow-md">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </button>
        <span class="text-[9px] font-semibold text-white drop-shadow-sm leading-none">66.5K</span>
      </div>

      {/* Comment Button */}
      <div class="flex flex-col items-center gap-0.5 group pointer-events-auto cursor-pointer">
        <button class="p-1 rounded-full hover:bg-white/10 active:scale-90 transition-all duration-150 text-white drop-shadow-md">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
            <path d="M20.656 17.008a9.993 9.993 0 1 0-3.59 3.615L22 22l-1.38-4.992Z"></path>
          </svg>
        </button>
        <span class="text-[9px] font-semibold text-white drop-shadow-sm leading-none">921</span>
      </div>

      {/* Repost/Remix Button */}
      <div class="flex flex-col items-center gap-0.5 group pointer-events-auto cursor-pointer">
        <button class="p-1 rounded-full hover:bg-white/10 active:scale-90 transition-all duration-150 text-white drop-shadow-md">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="17 1 21 5 17 9"></polyline>
            <path d="M3 11v-2a4 4 0 0 1 4-4h14"></path>
            <polyline points="7 23 3 19 7 15"></polyline>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
          </svg>
        </button>
        <span class="text-[9px] font-semibold text-white drop-shadow-sm leading-none">569</span>
      </div>

      {/* Share Button */}
      <div class="flex flex-col items-center gap-0.5 group pointer-events-auto cursor-pointer">
        <button class="p-1 rounded-full hover:bg-white/10 active:scale-90 transition-all duration-150 text-white drop-shadow-md">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
        <span class="text-[9px] font-semibold text-white drop-shadow-sm leading-none">7,845</span>
      </div>

      {/* Save Button */}
      <div class="flex flex-col items-center gap-0.5 group pointer-events-auto cursor-pointer">
        <button class="p-1 rounded-full hover:bg-white/10 active:scale-90 transition-all duration-150 text-white drop-shadow-md">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="20 21 12 13.44 4 21 4 3 20 3 20 21"></polygon>
          </svg>
        </button>
        <span class="text-[9px] font-semibold text-white drop-shadow-sm leading-none">2,732</span>
      </div>

      {/* More Button */}
      <div class="flex flex-col items-center group pointer-events-auto cursor-pointer">
        <button class="p-1 rounded-full hover:bg-white/10 active:scale-90 transition-all duration-150 text-white drop-shadow-md">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="5" r="1.5" fill="currentColor"></circle>
            <circle cx="12" cy="12" r="1.5" fill="currentColor"></circle>
            <circle cx="12" cy="19" r="1.5" fill="currentColor"></circle>
          </svg>
        </button>
      </div>

      {/* Audio Cover Disc (Spinning) */}
      <div class="w-6 h-6 rounded-[6px] border border-white/95 overflow-hidden bg-zinc-800 shadow-md flex items-center justify-center pointer-events-auto cursor-pointer animate-spin-slow mt-0.5 shrink-0">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-400">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>

    </div>

    {/* Hidden Bottom CTA Overlay to prevent JS errors */}
    <div id="overlay-bottom-cta" class="hidden"></div>

    {/* Bottom Navigation Overlay */}
    <div id="overlay-bottom-nav" class="reels-overlay absolute bottom-0 left-0 right-0 h-12 bg-black border-t border-white/10 text-white z-40 flex items-center justify-around select-none">
      {/* Home Button */}
      <button class="flex items-center justify-center w-10 h-10 text-white/90 hover:text-white active:scale-90 transition-all">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </button>

      {/* Reels Button (Active/Selected) */}
      <button class="flex items-center justify-center w-10 h-10 text-white active:scale-90 transition-all">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 4h-2l-2-3H9L7 4H5c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H5V8h14v10zm-9-8l6 4-6 4v-8z"/>
        </svg>
      </button>

      {/* Create Button */}
      <button class="flex items-center justify-center w-10 h-10 text-white/90 hover:text-white active:scale-90 transition-all">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
          <line x1="12" y1="8" x2="12" y2="16"></line>
          <line x1="8" y1="12" x2="16" y2="12"></line>
        </svg>
      </button>

      {/* Search Button */}
      <button class="flex items-center justify-center w-10 h-10 text-white/90 hover:text-white active:scale-90 transition-all">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>

      {/* Profile Button with notification dot */}
      <button class="flex items-center justify-center w-10 h-10 active:scale-90 transition-all">
        <div class="relative w-6 h-6 rounded-full border border-white/60 overflow-hidden bg-zinc-800 flex items-center justify-center shrink-0">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/80">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span class="absolute bottom-0 right-0 w-1.5 h-1.5 bg-red-500 rounded-full border border-black"></span>
        </div>
      </button>
    </div>

    {/* Portrait Feed Views Overlay */}
    <div id="portrait-views-overlay" class="absolute left-3 bottom-3 z-30 hidden items-center gap-1.5 bg-black/40 backdrop-blur-xs px-2.5 py-1 rounded-full text-white text-[11px] font-medium pointer-events-none select-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
      </svg>
      <span>67.7K</span>
    </div>

  </div>
</div>

<style>
  /* Hide Reels overlays in portrait feed mode */
  #mockup-container.format-portrait .reels-overlay {
    display: none !important;
  }

  /* Slow rotation for the audio disc */
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }

  /* Dynamic spacing and positioning styles for Instagram overlay control system */
  .bottom-overlay-area {
    bottom: 1rem; /* Default: 16px */
    transition: bottom 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Adjust bottom elements depending on active nav class state on container */
  #mockup-container.show-bottom-nav .bottom-overlay-area {
    bottom: 3.75rem; /* 60px (48px nav + 12px spacing) for realistic lower placement */
  }

  /* Viewport responsiveness for shorter screens to prevent vertical overflow */
  @media (max-height: 820px) {
    #mockup-container, #mockup-header-container {
      max-width: 320px;
    }
  }
  @media (max-height: 720px) {
    #mockup-container, #mockup-header-container {
      max-width: 285px;
    }
  }
  @media (max-height: 620px) {
    #mockup-container, #mockup-header-container {
      max-width: 240px;
    }
  }
</style>
