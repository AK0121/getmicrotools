---
// src/components/instagram-preview/SafeZoneGuide.astro
---
<div class="bg-surface-card border border-hairline p-8 rounded-xl space-y-6">
  <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-muted">Safe Zone Guide</h3>
  <div class="space-y-4">
    <div class="flex gap-4">
      <div class="w-1 h-12 bg-primary rounded-full shrink-0"></div>
      <div>
        <h4 class="text-ink font-medium text-sm mb-1">Bottom Overlay</h4>
        <p class="text-body text-xs leading-normal">Instagram places the username, caption, and audio track in the bottom 25%. Avoid putting critical text here.</p>
      </div>
    </div>
    <div class="flex gap-4">
      <div class="w-1 h-12 bg-surface-strong rounded-full shrink-0"></div>
      <div>
        <h4 class="text-ink font-medium text-sm mb-1">Right Action Bar</h4>
        <p class="text-body text-xs leading-normal">Engagement icons (Like, Comment, Share) sit on the right edge. Ensure subjects aren't framed too far right.</p>
      </div>
    </div>
  </div>
</div>
