---
// src/components/instagram-preview/UploadZone.astro
---
<div class="flex flex-col gap-4">
  <div 
    id="drop-zone"
    class="group relative border-2 border-dashed border-hairline hover:border-primary bg-surface-card rounded-xl p-12 text-center transition-all cursor-pointer"
  >
    <input 
      type="file" 
      id="file-upload" 
      accept="image/*,video/mp4" 
      class="absolute inset-0 opacity-0 cursor-pointer z-10"
    />
    <div class="space-y-6 pointer-events-none">
      <div class="w-20 h-20 bg-canvas-soft rounded-full flex items-center justify-center mx-auto border border-hairline group-hover:border-primary/50 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-muted group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
        </svg>
      </div>
      <div>
        <p class="text-ink text-xl font-medium mb-2">Drop your media here</p>
        <p class="text-muted text-sm">Supports images (JPG, PNG) and MP4 videos (9:16 recommended)</p>
      </div>
    </div>
  </div>

  <button
    type="button"
    id="clear-media-btn"
    class="hidden w-full py-2.5 px-4 text-xs font-semibold text-[#cf2d56] hover:bg-[#cf2d56]/10 border border-[#cf2d56]/20 rounded-lg transition-all duration-150 cursor-pointer justify-center items-center gap-2"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
    </svg>
    Remove Media
  </button>
</div>
