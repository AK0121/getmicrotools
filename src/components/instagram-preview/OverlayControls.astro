---
// src/components/instagram-preview/OverlayControls.astro
---
<div class="bg-surface-card border border-hairline p-6 rounded-xl space-y-6">
  <div>
    <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-muted mb-1">UI Overlay Layers</h3>
    <p class="text-xs text-muted">Toggle layers to preview how they cover your Reel's content.</p>
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <!-- Top Header Toggle -->
    <div class="flex items-center justify-between p-3.5 bg-canvas-soft border border-hairline/50 rounded-lg hover:border-hairline transition-colors">
      <div class="space-y-0.5 pr-2">
        <label for="toggle-top-header" class="text-xs font-semibold text-ink cursor-pointer select-none">Top Header</label>
        <p class="text-[10px] text-muted leading-tight">Logo, back button, camera icon</p>
      </div>
      <label class="relative inline-flex items-center cursor-pointer shrink-0">
        <input type="checkbox" id="toggle-top-header" class="sr-only peer" checked>
        <div class="w-9 h-5 bg-zinc-800 rounded-full peer peer-checked:after:translate-x-4 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
      </label>
    </div>

    <!-- Right Action Bar Toggle -->
    <div class="flex items-center justify-between p-3.5 bg-canvas-soft border border-hairline/50 rounded-lg hover:border-hairline transition-colors">
      <div class="space-y-0.5 pr-2">
        <label for="toggle-right-action" class="text-xs font-semibold text-ink cursor-pointer select-none">Right Action Bar</label>
        <p class="text-[10px] text-muted leading-tight">Like, Comment, Share, Music Disc</p>
      </div>
      <label class="relative inline-flex items-center cursor-pointer shrink-0">
        <input type="checkbox" id="toggle-right-action" class="sr-only peer" checked>
        <div class="w-9 h-5 bg-zinc-800 rounded-full peer peer-checked:after:translate-x-4 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
      </label>
    </div>

    <!-- Profile Section Toggle -->
    <div class="flex items-center justify-between p-3.5 bg-canvas-soft border border-hairline/50 rounded-lg hover:border-hairline transition-colors">
      <div class="space-y-0.5 pr-2">
        <label for="toggle-profile" class="text-xs font-semibold text-ink cursor-pointer select-none">Profile Section</label>
        <p class="text-[10px] text-muted leading-tight">Avatar, username, Follow button</p>
      </div>
      <label class="relative inline-flex items-center cursor-pointer shrink-0">
        <input type="checkbox" id="toggle-profile" class="sr-only peer" checked>
        <div class="w-9 h-5 bg-zinc-800 rounded-full peer peer-checked:after:translate-x-4 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
      </label>
    </div>

    <!-- Caption Toggle -->
    <div class="flex items-center justify-between p-3.5 bg-canvas-soft border border-hairline/50 rounded-lg hover:border-hairline transition-colors">
      <div class="space-y-0.5 pr-2">
        <label for="toggle-caption" class="text-xs font-semibold text-ink cursor-pointer select-none">Caption & Audio</label>
        <p class="text-[10px] text-muted leading-tight">Text caption, hashtags, audio track</p>
      </div>
      <label class="relative inline-flex items-center cursor-pointer shrink-0">
        <input type="checkbox" id="toggle-caption" class="sr-only peer" checked>
        <div class="w-9 h-5 bg-zinc-800 rounded-full peer peer-checked:after:translate-x-4 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
      </label>
    </div>

    <!-- Hidden Bottom CTA Toggle to prevent JS exceptions in caller pages -->
    <input type="checkbox" id="toggle-bottom-cta" class="hidden">

    <!-- Bottom Navigation Toggle -->
    <div class="flex items-center justify-between p-3.5 bg-canvas-soft border border-hairline/50 rounded-lg hover:border-hairline transition-colors">
      <div class="space-y-0.5 pr-2">
        <label for="toggle-bottom-nav" class="text-xs font-semibold text-ink cursor-pointer select-none">Bottom Navigation</label>
        <p class="text-[10px] text-muted leading-tight">Instagram main menu bar</p>
      </div>
      <label class="relative inline-flex items-center cursor-pointer shrink-0">
        <input type="checkbox" id="toggle-bottom-nav" class="sr-only peer" checked>
        <div class="w-9 h-5 bg-zinc-800 rounded-full peer peer-checked:after:translate-x-4 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
      </label>
    </div>
  </div>
</div>
