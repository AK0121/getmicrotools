---
const tools = [
  { title: "Engagement Calculator", href: "/engagement-rate-calculator" },
  { title: "Instagram Reels Tester", href: "/instagram-reels-overlay-tester" },
  { title: "ROAS & Profitability", href: "/roas-calculator" },
  { title: "LinkedIn Preview Formatter", href: "/linkedin-preview-formatter" },
];

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About Us" },
  { href: "/contact", label: "Contact Us" },
  { href: "/terms", label: "Terms & Conditions" },
];
---

<footer class="bg-canvas border-t border-hairline py-16 px-6 md:px-12 mt-20 transition-colors duration-500">
  <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-y-12 gap-x-8">
    <div class="sm:col-span-2">
      <a href="/" class="text-ink font-semibold text-lg tracking-tight mb-4 block">
        Get <span class="text-primary">Micro</span> Tools
      </a>
      <p class="text-body text-sm max-w-xs leading-relaxed">
        The ultimate collection of utilities for digital entrepreneurs. Built for speed, designed for clarity.
      </p>
    </div>
    
    <div>
      <h4 class="text-ink font-semibold text-sm mb-4 font-mono uppercase tracking-wider">Tools</h4>
      <ul class="space-y-2">
        {tools.map(tool => (
          <li><a href={tool.href} class="text-body hover:text-ink text-sm transition-colors">{tool.title}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-ink font-semibold text-sm mb-4 font-mono uppercase tracking-wider">Pages</h4>
      <ul class="space-y-2">
        {navLinks.map(link => (
          <li><a href={link.href} class="text-body hover:text-ink text-sm transition-colors">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-ink font-semibold text-sm mb-4 font-mono uppercase tracking-wider">Connect</h4>
      <ul class="space-y-2">
        <li><a href="mailto:hello@getmicrotools.com" class="text-body hover:text-ink text-sm transition-colors">Email Us</a></li>
        <li><a href="https://x.com/getmicrotools" target="_blank" rel="noopener noreferrer" class="text-body hover:text-ink text-sm transition-colors">Follow on X</a></li>
      </ul>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto pt-12 mt-12 border-t border-hairline-soft flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="text-muted text-xs">
      &copy; {new Date().getFullYear()} Get Micro Tools. All rights reserved.
    </p>
    <div class="flex gap-6">
      <a href="/terms" class="text-muted hover:text-ink text-xs transition-colors">Privacy Policy</a>
      <a href="/terms" class="text-muted hover:text-ink text-xs transition-colors">Terms of Service</a>
      <a href="/contact" class="text-muted hover:text-ink text-xs transition-colors">Support</a>
    </div>
  </div>
</footer>
